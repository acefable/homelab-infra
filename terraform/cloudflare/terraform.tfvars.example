# ──────────────────────────────────────────────
# Cloudflare module — Terraform variables
# ──────────────────────────────────────────────
#
# This file is for the ingress_rules variable, which
# is a complex list that's easier to write in HCL
# than as a JSON-encoded TF_VAR_ environment variable.
#
# To use:
#   1. Copy this file to terraform.tfvars
#      (terraform.tfvars is gitignored — safe)
#
#   2. Uncomment and customize the ingress_rules below
#
#   3. Run: terraform apply
# ──────────────────────────────────────────────

ingress_rules = [
  {
    hostname = "whoami.acefable.com"
    service  = "http://localhost:31337"
  },
  {
    hostname = "argocd.acefable.com"
    service  = "http://argocd-server.argocd.svc.cluster.local:443"
  }
]
