# ──────────────────────────────────────────────
# Cloudflare module — Example tfvars
# ──────────────────────────────────────────────
# Copy this file to terraform.tfvars and replace
# the placeholder values with your own.
#
# All values come from your .env file (see .env.example):
#   cp terraform.tfvars.example terraform.tfvars
#
# terraform.tfvars is gitignored and will NOT be
# committed to version control.
#
# Alternatively, you can use TF_VAR_ environment
# variables instead of this file, e.g.:
#   export TF_VAR_cloudflare_api_token=$CF_API_TOKEN
# ──────────────────────────────────────────────

cloudflare_api_token    = "your-cloudflare-api-token"      # from: CF_API_TOKEN
cloudflare_account_id   = "your-cloudflare-account-id"     # from: CF_ACCOUNT_ID
zone_id                 = "your-cloudflare-zone-id"        # from: CF_ZONE_ID
tunnel_secret           = "your-base64-encoded-32-byte-secret"  # from: CF_TUNNEL_SECRET

tunnel_name = "homelab-tunnel"

ingress_rules = [
  {
    hostname = "grafana.example.com"
    service  = "http://localhost:3000"
  },
  {
    hostname = "gitea.example.com"
    service  = "http://localhost:3001"
  },
]
