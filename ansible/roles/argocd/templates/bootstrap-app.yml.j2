apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: {{ argocd_app_name }}
  namespace: {{ argocd_namespace }}
spec:
  project: default
  source:
    repoURL: {{ argocd_repo_url }}
    targetRevision: {{ argocd_target_revision }}
    path: {{ argocd_app_path }}
    directory:
      recurse: true
  destination:
    server: https://kubernetes.default.svc
    namespace: {{ argocd_app_destination_namespace }}
  syncPolicy:
    automated:
      prune: {{ argocd_prune | lower }}
      selfHeal: {{ argocd_self_heal | lower }}
      allowEmpty: false
    syncOptions:
      - Validate=true
      - CreateNamespace=true
      - PrunePropagationPolicy=foreground
      - PruneLast=true
    retry:
      limit: 5
      backoff:
        duration: 5s
        factor: 2
        maxDuration: 3m
