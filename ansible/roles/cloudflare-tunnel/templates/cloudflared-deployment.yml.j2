apiVersion: v1
kind: Namespace
metadata:
  name: {{ cloudflare_tunnel_namespace }}
---
apiVersion: v1
kind: Secret
metadata:
  name: cloudflare-tunnel-token
  namespace: {{ cloudflare_tunnel_namespace }}
stringData:
  token: {{ cloudflare_tunnel_token }}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: cloudflared
  namespace: {{ cloudflare_tunnel_namespace }}
  labels:
    app: cloudflared
spec:
  replicas: 1
  selector:
    matchLabels:
      app: cloudflared
  template:
    metadata:
      labels:
        app: cloudflared
    spec:
      containers:
        - name: cloudflared
          image: cloudflare/cloudflared:latest
          command:
            - cloudflared
            - tunnel
            - run
          args:
            - --token
            - $(TUNNEL_TOKEN)
          env:
            - name: TUNNEL_TOKEN
              valueFrom:
                secretKeyRef:
                  name: cloudflare-tunnel-token
                  key: token
          resources:
            requests:
              cpu: 100m
              memory: 128Mi
            limits:
              cpu: 200m
              memory: 256Mi
