# ============================================
# homelab-infra — Environment Variables
# ============================================
# Copy this file to .env and populate with your values.
# The .env file is gitignored and will NOT be committed.
#
# Usage:
#   cp .env.example .env
#   source .env    # or use dotenv, direnv, etc.

# ── Ansible ──────────────────────────────────
# SSH user for Ansible connections (default: ubuntu)
export ANSIBLE_USER=ubuntu

# Path to the SSH private key for Ansible connections
# (default: ~/.ssh/id_ed25519)
export ANSIBLE_SSH_PRIVATE_KEY_FILE=~/.ssh/homelab_ed25519

# IP address or hostname of the target server
# (192.168.1.100 is a placeholder — replace with your actual IP)
export HOMELAB_SERVER_IP=192.168.1.100

# System hostname to set on the target server
# (default: ubuntu-server)
export HOMELAB_HOSTNAME=ubuntu-server

# APT mirror URL (default: http://archive.ubuntu.com/ubuntu)
# Change if your server's country mirror is unreliable
export APT_MIRROR=http://archive.ubuntu.com/ubuntu

# ── Cloudflare (Terraform reads TF_VAR_* directly) ──
# API token with Tunnel:Edit and DNS:Edit permissions
export TF_VAR_cloudflare_api_token=
# Cloudflare account ID (matches Terraform's cloudflare_account_id)
export TF_VAR_cloudflare_account_id=
# Zone ID for the managed domain
export TF_VAR_zone_id=
# Pre-generated 32-byte base64-encoded tunnel secret
# Generate with: openssl rand -base64 32
export TF_VAR_tunnel_secret=
# Tunnel name (default: homelab-tunnel)
export TF_VAR_tunnel_name="homelab-tunnel"
# Tunnel ID (from Terraform output, set after first apply)
export TF_VAR_cloudflare_tunnel_id=
# Tunnel token (from Terraform output, used by Ansible for cloudflared auth)
export TF_VAR_cloudflare_tunnel_token=
